# 검색·공유 메타데이터에는 실제 공개 HTTPS 주소를 사용합니다.
NEXT_PUBLIC_SITE_URL=https://danielsnote.com
# 방문자가 동의한 경우에만 Google Analytics를 실행합니다.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# 국내 결제 심사와 판매 오픈 전 실제 공개 고객센터 번호를 입력합니다.
NEXT_PUBLIC_BUSINESS_PHONE=
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_REDIRECT_URI=https://danielsnote.com/api/auth/google/callback
GOOGLE_SESSION_SECRET=generate-a-long-random-secret
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# 카카오 계정 연결 해제/회원 탈퇴 시 카카오 플랫폼 연결도 해제하려면 설정합니다.
KAKAO_ADMIN_KEY=
KAKAO_REDIRECT_URI=https://danielsnote.com/api/auth/kakao/callback
# 로컬 테스트 시 Kakao Developers의 Redirect URI에도 아래 주소를 추가하고 이 값으로 바꿉니다.
# KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback
# 결제 승인·환불 상태 메일. 발신 주소는 Resend에서 도메인 인증을 마친 주소여야 합니다.
RESEND_API_KEY=
TRANSACTIONAL_EMAIL_FROM=
# 자동 메일의 답장과 고객 문의를 실제로 받을 주소입니다.
CUSTOMER_SUPPORT_EMAIL=florencelab@naver.com
ADMIN_EMAILS=owner@example.com
TEST_PURCHASER_EMAILS=oxaz1234@gmail.com
# 외부 OAuth 없이 QA할 때만 켠다. 비밀번호는 24자 이상을 사용한다.
# 운영 배포에서는 QA_LOGIN_ALLOW_PRODUCTION까지 true여야 동작하며, QA가 끝나면 즉시 둘 다 false로 돌린다.
QA_LOGIN_ENABLED=false
QA_LOGIN_ALLOW_PRODUCTION=false
QA_ADMIN_EMAIL=qa-admin@example.test
QA_ADMIN_PASSWORD=replace-with-at-least-24-random-characters
NEXT_PUBLIC_KAKAOPAY_ENABLED=false
KAKAOPAY_CID=
KAKAOPAY_SECRET_KEY=
NEXT_PUBLIC_NAVERPAY_ENABLED=false
NAVERPAY_MODE=development
NAVERPAY_CLIENT_ID=
NAVERPAY_CLIENT_SECRET=
NAVERPAY_CHAIN_ID=
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_CODEX_PRICE_ID=
NEXT_PUBLIC_CAREER_PRICE_ID=
NEXT_PUBLIC_JANE_PRICE_ID=
PADDLE_API_KEY=
PADDLE_NOTIFICATION_WEBHOOK_SECRET=

# Paddle 대신 파일 전달까지 처리하는 외부 판매 페이지를 사용한다면 아래 주소를 설정합니다.
# NEXT_PUBLIC_CODEX_PURCHASE_URL=https://your-store.example/codex-book
# NEXT_PUBLIC_CAREER_PURCHASE_URL=https://your-store.example/career-book
# NEXT_PUBLIC_JANE_PURCHASE_URL=https://your-store.example/jane-book
